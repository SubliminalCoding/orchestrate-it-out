#!/usr/bin/env bash
# Run GPT-5.6 Sol planning followed by exactly five Fable 5 workers.
set -euo pipefail

PACKAGE_VERSION="0.1.1"
PROTOCOL_VERSION="1"
ORCHESTRATOR_MODEL="gpt-5.6-sol"
WORKER_MODEL="claude-fable-5"
PROJECT_DIR="$PWD"
RUN_ID="oio-$(date -u +%Y%m%d-%H%M%S)-$$"
PLAN_TIMEOUT=1800
WORKER_TIMEOUT=1800
MAX_PLAN_ATTEMPTS=2
DRY_RUN=0
TRUSTED_TASK=0
KEEP_SESSION=0
UNCONTAINED_ORCHESTRATOR=0
TASK_PARTS=()
SESSION_CREATED=0
RUNTIME_DIR=""

usage() {
  cat <<'EOF'
orchestrate-it-out — Sol plans, exactly five Fable 5 workers build

USAGE:
  orchestrate-it-out "<substantial implementation task>" [options]

OPTIONS:
  --project DIR                 Target clean Git repository (default: current)
  --max-plan-attempts N         Structural plan attempts, 1-3 (default: 2)
  --plan-timeout SEC            Sol planning timeout, 60-3600 (default: 1800)
  --worker-timeout SEC          Per dependency-wave timeout, 60-7200 (default: 1800)
  --run-id ID                   Safe unique NTM label
  --uncontained-orchestrator    Disable Sol's read-only Codex sandbox explicitly
  --keep-session                Retain the exact five-worker NTM session
  --trusted-task                Acknowledge agent permissions and provider data flow
  --dry-run                     Inspect topology, commands, and prompt; launch nothing
  --version                     Show package and protocol versions
  -h, --help                    Show this help

The repository must be clean. The workflow forbids commits, pushes, dependency
installation, deploys, publishing, external-service mutation, and nested agent
boards. Fable workers run unattended with the caller's permissions; repository
gates are detective controls, not OS containment. There is intentionally no
semantic reviewer after the deterministic final gate.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 2
}

need_value() {
  local flag="$1" count="$2" value="${3:-}"
  [[ "$count" -ge 2 && -n "$value" && "$value" != --* ]] || die "$flag requires a value"
}

require_range() {
  local flag="$1" value="$2" minimum="$3" maximum="$4"
  [[ "$value" =~ ^[0-9]+$ ]] || die "$flag must be an integer from $minimum to $maximum"
  (( value >= minimum && value <= maximum )) || die "$flag must be from $minimum to $maximum"
}

print_command() {
  printf '  '
  printf '%q ' "$@"
  printf '\n'
}

canonical_path() {
  local target="$1" directory link hops=0
  while [[ -L "$target" ]]; do
    ((hops += 1))
    (( hops <= 40 )) || return 1
    directory="$(cd -P -- "$(dirname -- "$target")" && pwd)" || return 1
    link="$(readlink "$target")" || return 1
    if [[ "$link" = /* ]]; then target="$link"; else target="$directory/$link"; fi
  done
  directory="$(cd -P -- "$(dirname -- "$target")" && pwd)" || return 1
  printf '%s/%s\n' "$directory" "$(basename -- "$target")"
}

while (($#)); do
  case "$1" in
    --project) need_value "$1" "$#" "${2:-}"; PROJECT_DIR="$2"; shift 2 ;;
    --max-plan-attempts) need_value "$1" "$#" "${2:-}"; MAX_PLAN_ATTEMPTS="$2"; shift 2 ;;
    --plan-timeout) need_value "$1" "$#" "${2:-}"; PLAN_TIMEOUT="$2"; shift 2 ;;
    --worker-timeout) need_value "$1" "$#" "${2:-}"; WORKER_TIMEOUT="$2"; shift 2 ;;
    --run-id) need_value "$1" "$#" "${2:-}"; RUN_ID="$2"; shift 2 ;;
    --uncontained-orchestrator) UNCONTAINED_ORCHESTRATOR=1; shift ;;
    --keep-session) KEEP_SESSION=1; shift ;;
    --trusted-task) TRUSTED_TASK=1; shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --version) printf 'orchestrate-it-out %s (protocol %s)\n' "$PACKAGE_VERSION" "$PROTOCOL_VERSION"; exit 0 ;;
    -h|--help) usage; exit 0 ;;
    --) shift; TASK_PARTS+=("$@"); break ;;
    --*) die "unknown flag: $1" ;;
    *) TASK_PARTS+=("$1"); shift ;;
  esac
done

((${#TASK_PARTS[@]})) || die "no task description given"
TASK="${TASK_PARTS[*]}"
require_range "--max-plan-attempts" "$MAX_PLAN_ATTEMPTS" 1 3
require_range "--plan-timeout" "$PLAN_TIMEOUT" 60 3600
require_range "--worker-timeout" "$WORKER_TIMEOUT" 60 7200
[[ "$RUN_ID" =~ ^[A-Za-z0-9][A-Za-z0-9_-]{0,49}$ && "$RUN_ID" != *--* ]] \
  || die "--run-id must be 1-50 safe characters and may not contain --"
if (( DRY_RUN == 0 && TRUSTED_TASK == 0 )); then
  die "live runs require --trusted-task to acknowledge unattended worker permissions and provider data flow"
fi
[[ -d "$PROJECT_DIR" ]] || die "project directory not found: $PROJECT_DIR"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd -P)"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
[[ "$PROJECT_NAME" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$ && "$PROJECT_NAME" != *--* ]] \
  || die "repository basename is not a safe NTM project name: $PROJECT_NAME"
SESSION="$PROJECT_NAME--$RUN_ID"

SCRIPT_PATH="$(canonical_path "${BASH_SOURCE[0]}")"
SKILL_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd -P)"
PROTOCOL="$SKILL_DIR/scripts/protocol.py"
PLAN_SCHEMA="$SKILL_DIR/assets/plan-schema.json"
SOL_TEMPLATE="$SKILL_DIR/assets/sol-orchestrator-prompt.md"
NTM_TEMPLATE="$SKILL_DIR/assets/ntm.toml"
for resource in "$PROTOCOL" "$PLAN_SCHEMA" "$SOL_TEMPLATE" "$NTM_TEMPLATE"; do
  [[ -f "$resource" ]] || die "missing skill resource: $resource"
done

for executable in git python3; do
  command -v "$executable" >/dev/null || die "$executable is not on PATH"
done

umask 077
RUNTIME_PARENT="${XDG_RUNTIME_DIR:-/tmp}"
[[ -d "$RUNTIME_PARENT" && -w "$RUNTIME_PARENT" ]] || RUNTIME_PARENT=/tmp
RUNTIME_DIR="$(mktemp -d "$RUNTIME_PARENT/orchestrate-it-out.${RUN_ID}.XXXXXX")"
TASK_FILE="$RUNTIME_DIR/task.txt"
BASELINE_FILE="$RUNTIME_DIR/baseline.json"
STATE_FILE="$RUNTIME_DIR/run-state.json"
SOL_PROMPT="$RUNTIME_DIR/sol-prompt.md"
VALIDATION_FILE="$RUNTIME_DIR/plan-validation.json"
ROSTER_FILE="$RUNTIME_DIR/worker-roster.json"
BRIEFS_DIR="$RUNTIME_DIR/briefs"
EVIDENCE_FILE="$RUNTIME_DIR/final-evidence.json"
NTM_CONFIG_FILE="$RUNTIME_DIR/ntm.toml"
TMUX_PANES_FILE="$RUNTIME_DIR/tmux-panes.txt"

session_exists() {
  tmux has-session -t "=$SESSION" 2>/dev/null
}

kill_exact_session() {
  NTM_CONFIG="$NTM_CONFIG_FILE" ntm kill "$SESSION" --force --no-hooks >/dev/null 2>&1 || true
  if session_exists; then tmux kill-session -t "=$SESSION" >/dev/null 2>&1 || true; fi
  ! session_exists
}

cleanup() {
  local status=$?
  trap - EXIT INT TERM
  if (( SESSION_CREATED == 1 && (status != 0 || KEEP_SESSION == 0) )); then
    if ! kill_exact_session; then
      printf 'warning: exact session could not be proven removed: %s\n' "$SESSION" >&2
    fi
  fi
  if (( DRY_RUN == 1 )); then rm -rf "$RUNTIME_DIR"; fi
  exit "$status"
}
trap cleanup EXIT INT TERM

printf '%s\n' "$TASK" > "$TASK_FILE"
python3 "$PROTOCOL" preflight --project "$PROJECT_DIR" --output "$BASELINE_FILE" >/dev/null
IS_CLEAN="$(python3 -c 'import json,sys; print(1 if json.load(open(sys.argv[1]))["clean"] else 0)' "$BASELINE_FILE")"
if (( IS_CLEAN == 0 )); then
  DIRTY="$(python3 -c 'import json,sys; print("\n".join(json.load(open(sys.argv[1]))["dirtyPaths"]))' "$BASELINE_FILE")"
  die "repository must start clean; current changed paths: ${DIRTY:-unknown}"
fi

python3 "$PROTOCOL" init-state \
  --state "$STATE_FILE" --run-id "$RUN_ID" --task-file "$TASK_FILE" \
  --baseline "$BASELINE_FILE" --orchestrator-model "$ORCHESTRATOR_MODEL" \
  --worker-model "$WORKER_MODEL"
cp "$NTM_TEMPLATE" "$NTM_CONFIG_FILE"

while IFS= read -r line || [[ -n "$line" ]]; do
  if [[ "$line" == '{{TASK}}' ]]; then printf '%s\n' "$TASK"; else printf '%s\n' "$line"; fi
done < "$SOL_TEMPLATE" > "$SOL_PROMPT"

PLANNER_SANDBOX=(--sandbox read-only)
if (( UNCONTAINED_ORCHESTRATOR == 1 )); then
  PLANNER_SANDBOX=(--dangerously-bypass-approvals-and-sandbox)
fi
PLANNER_BASE=(
  codex exec
  --model "$ORCHESTRATOR_MODEL"
  --cd "$PROJECT_DIR"
  "${PLANNER_SANDBOX[@]}"
  --ephemeral
  --disable multi_agent
  --output-schema "$PLAN_SCHEMA"
  --color never
  -c 'approval_policy="never"'
)

export NTM_PROJECTS_BASE="$(dirname "$PROJECT_DIR")"
export NTM_CONFIG="$NTM_CONFIG_FILE"

if (( DRY_RUN == 1 )); then
  printf '[dry-run] Sol -> exactly five Fable 5 workers\n'
  printf '  project: %s\n  session: %s\n  orchestrator: %s\n  workers: 5 x %s\n' \
    "$PROJECT_DIR" "$SESSION" "$ORCHESTRATOR_MODEL" "$WORKER_MODEL"
  printf '  orchestrator containment: '
  if (( UNCONTAINED_ORCHESTRATOR == 1 )); then printf 'explicitly uncontained\n'; else printf 'Codex read-only sandbox\n'; fi
  print_command "${PLANNER_BASE[@]}" --output-last-message '<attempt-plan.json>' -
  print_command python3 "$PROTOCOL" validate-plan --project "$PROJECT_DIR" \
    --task-file "$TASK_FILE" --plan '<attempt-plan.json>' --output "$VALIDATION_FILE"
  print_command python3 "$PROTOCOL" seal --state "$STATE_FILE" \
    --plan '<validated-plan.json>' --validation "$VALIDATION_FILE"
  print_command python3 "$PROTOCOL" claim-workers --state "$STATE_FILE" --validation "$VALIDATION_FILE"
  printf '  ordering: Sol plan is validated and sealed before any Fable session exists\n'
  print_command ntm spawn "$PROJECT_NAME" --label "$RUN_ID" --cc="5:$WORKER_MODEL" \
    --no-user --safety --no-recovery --no-cass-context --no-hooks --ready-timeout 2m
  printf '  then: validate manifest/tmux roster -> render five exact briefs -> exact-pane sends\n'
  printf '  then: dependency-wave waits + five receipts -> deterministic final gate\n'
  printf '  final semantic reviewer: intentionally absent\n\n'
  cat "$SOL_PROMPT"
  exit 0
fi

for executable in codex claude ntm tmux; do
  command -v "$executable" >/dev/null || die "$executable is not on PATH"
done
command -v timeout >/dev/null || die "GNU timeout is required for bounded planning"

PLAN_FILE=""
VALID_PLAN=0
PREVIOUS_ERROR=""
for ((attempt = 1; attempt <= MAX_PLAN_ATTEMPTS; attempt += 1)); do
  ATTEMPT_PROMPT="$RUNTIME_DIR/sol-prompt-attempt-$attempt.md"
  PLAN_CANDIDATE="$RUNTIME_DIR/plan-attempt-$attempt.json"
  if (( attempt == 1 )); then
    cp "$SOL_PROMPT" "$ATTEMPT_PROMPT"
  else
    cp "$SOL_PROMPT" "$ATTEMPT_PROMPT"
    {
      printf '\n## Previous structural failure\n\n'
      printf '%s\n' "$PREVIOUS_ERROR"
      printf '\nReturn a corrected plan. Do not weaken or omit required detail.\n'
    } >> "$ATTEMPT_PROMPT"
  fi
  printf '>> Sol planning attempt %s/%s with %s\n' "$attempt" "$MAX_PLAN_ATTEMPTS" "$ORCHESTRATOR_MODEL"
  PLANNER_LOG="$RUNTIME_DIR/sol-attempt-$attempt.log"
  planner_status=0
  timeout --foreground "$PLAN_TIMEOUT" \
    "${PLANNER_BASE[@]}" --output-last-message "$PLAN_CANDIDATE" - \
    < "$ATTEMPT_PROMPT" > "$PLANNER_LOG" 2>&1 || planner_status=$?
  if (( planner_status != 0 )); then
    PREVIOUS_ERROR="Sol process failed with exit $planner_status; inspect $PLANNER_LOG"
    continue
  fi
  VALIDATION_CANDIDATE="$RUNTIME_DIR/plan-validation-attempt-$attempt.json"
  VALIDATION_LOG="$RUNTIME_DIR/plan-validation-attempt-$attempt.log"
  validation_status=0
  python3 "$PROTOCOL" validate-plan --project "$PROJECT_DIR" --task-file "$TASK_FILE" \
    --plan "$PLAN_CANDIDATE" --output "$VALIDATION_CANDIDATE" \
    > "$VALIDATION_LOG" 2>&1 || validation_status=$?
  if (( validation_status != 0 )); then
    PREVIOUS_ERROR="$(tail -c 4000 "$VALIDATION_LOG")"
    continue
  fi
  PLAN_FILE="$PLAN_CANDIDATE"
  VALIDATION_FILE="$VALIDATION_CANDIDATE"
  VALID_PLAN=1
  break
done
(( VALID_PLAN == 1 )) || die "Sol did not produce a valid sealed plan after $MAX_PLAN_ATTEMPTS attempts; artifacts: $RUNTIME_DIR"

python3 "$PROTOCOL" seal --state "$STATE_FILE" --plan "$PLAN_FILE" --validation "$VALIDATION_FILE"
python3 "$PROTOCOL" claim-workers --state "$STATE_FILE" --validation "$VALIDATION_FILE"

if session_exists; then die "exact session already exists: $SESSION"; fi
printf '>> Sealed plan accepted; spawning exactly five %s workers\n' "$WORKER_MODEL"
spawn_status=0
ntm spawn "$PROJECT_NAME" --label "$RUN_ID" --cc="5:$WORKER_MODEL" \
  --no-user --safety --no-recovery --no-cass-context --no-hooks --ready-timeout 2m \
  || spawn_status=$?
if session_exists; then SESSION_CREATED=1; fi
(( spawn_status == 0 )) || exit "$spawn_status"
(( SESSION_CREATED == 1 )) || die "NTM reported success but exact session was not created: $SESSION"

MANIFEST_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/ntm/manifests"
MANIFEST_FILE="$MANIFEST_ROOT/$SESSION.json"
for _ in {1..40}; do [[ -f "$MANIFEST_FILE" ]] && break; sleep 0.25; done
[[ -f "$MANIFEST_FILE" ]] || die "NTM manifest was not created: $MANIFEST_FILE"
tmux list-panes -t "$SESSION" -F '#{pane_id}:#{pane_index}' > "$TMUX_PANES_FILE"
python3 "$PROTOCOL" register-workers --state "$STATE_FILE" --validation "$VALIDATION_FILE" \
  --session "$SESSION" --worker-model "$WORKER_MODEL" --manifest "$MANIFEST_FILE" \
  --tmux-panes "$TMUX_PANES_FILE" --output "$ROSTER_FILE"
python3 "$PROTOCOL" render-briefs --state "$STATE_FILE" --validation "$VALIDATION_FILE" \
  --output-dir "$BRIEFS_DIR" >/dev/null

mapfile -t WAVES < <(python3 -c 'import json,sys; print("\n".join(",".join(w) for w in json.load(open(sys.argv[1]))["waves"]))' "$VALIDATION_FILE")
WAVE_NUMBER=0
for wave in "${WAVES[@]}"; do
  ((WAVE_NUMBER += 1))
  IFS=',' read -r -a WAVE_WORKERS <<< "$wave"
  PANE_CSV=""
  printf '>> Dispatching sealed wave: %s\n' "$wave"
  for worker in "${WAVE_WORKERS[@]}"; do
    pane="$(python3 -c 'import json,sys; r=json.load(open(sys.argv[1])); print(next(w["paneIndex"] for w in r["workers"] if w["id"] == sys.argv[2]))' "$ROSTER_FILE" "$worker")"
    if [[ -n "$PANE_CSV" ]]; then PANE_CSV+=","; fi
    PANE_CSV+="$pane"
    SEND_RESPONSE="$RUNTIME_DIR/send-$worker.json"
    SEND_ERROR="$RUNTIME_DIR/send-$worker.stderr"
    send_status=0
    ntm --robot-send="$SESSION" --msg-file="$BRIEFS_DIR/$worker.md" --panes="$pane" \
      --track --timeout=2m --poll=500ms > "$SEND_RESPONSE" 2> "$SEND_ERROR" \
      || send_status=$?
    if (( send_status != 0 )) || ! python3 "$PROTOCOL" validate-send \
      --response "$SEND_RESPONSE" --session "$SESSION" --pane "$pane"; then
      ntm --robot-tail="$SESSION" --panes="$pane" --lines=120 || true
      die "exact-pane delivery was not proven for $worker on pane $pane"
    fi
  done
  WAVE_STATUS_FILE="$RUNTIME_DIR/wave-$WAVE_NUMBER-status.json"
  WAVE_ACTIVITY_FILE="$RUNTIME_DIR/wave-$WAVE_NUMBER-activity.json"
  deadline=$((SECONDS + WORKER_TIMEOUT))
  while true; do
    receipt_status=0
    python3 "$PROTOCOL" wave-status --state "$STATE_FILE" --workers "$wave" \
      > "$WAVE_STATUS_FILE" || receipt_status=$?
    if (( receipt_status == 0 )); then break; fi
    if (( receipt_status >= 2 )); then die "receipt state validation failed for wave: $wave"; fi
    blocked_count="$(python3 -c 'import json,sys; print(len(json.load(open(sys.argv[1]))["blocked"]))' "$WAVE_STATUS_FILE")"
    if (( blocked_count > 0 )); then
      ntm --robot-tail="$SESSION" --panes="$PANE_CSV" --lines=120 || true
      die "a worker recorded BLOCKED in wave: $wave"
    fi
    session_exists || die "worker session disappeared before receipts completed: $SESSION"
    if (( SECONDS >= deadline )); then
      ntm --robot-tail="$SESSION" --panes="$PANE_CSV" --lines=120 || true
      die "timed out waiting for atomic COMPLETE receipts from wave: $wave"
    fi
    ntm --robot-is-working="$SESSION" --panes="$PANE_CSV" \
      > "$WAVE_ACTIVITY_FILE" 2>&1 || true
    sleep 2
  done
  SETTLE_RESPONSE="$RUNTIME_DIR/wave-$WAVE_NUMBER-settle.json"
  settle_status=0
  ntm --robot-wait="$SESSION" --wait-until=idle --panes="$PANE_CSV" \
    --wait-exit-on-error --timeout=2m --poll=2s > "$SETTLE_RESPONSE" 2>&1 \
    || settle_status=$?
  if (( settle_status != 0 )) || ! python3 "$PROTOCOL" validate-robot-success --response "$SETTLE_RESPONSE"; then
    ntm --robot-tail="$SESSION" --panes="$PANE_CSV" --lines=120 || true
    die "completed worker wave did not settle cleanly: $wave"
  fi
done

printf '>> Running deterministic integration gate (no semantic reviewer)\n'
if ! python3 "$PROTOCOL" final-gate --state "$STATE_FILE" \
  --validation "$VALIDATION_FILE" --output "$EVIDENCE_FILE"; then
  die "final mechanical gate failed; evidence: $EVIDENCE_FILE"
fi

if (( KEEP_SESSION == 0 )); then
  kill_exact_session || die "could not prove exact session cleanup: $SESSION"
  SESSION_CREATED=0
else
  printf '>> Session retained: ntm attach %s\n' "$SESSION"
fi
printf 'DONE — mechanically green; independent semantic review intentionally omitted.\n'
printf 'Audit artifacts: %s\n' "$RUNTIME_DIR"
